{
  "name": "flower-sandbox",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "start": "npx expo start",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "dev": "npx expo start",
    "dev:go": "npx expo start --go",
    "dev:tunnel": "npx expo start --tunnel",
    "dev:web": "npx expo start --web",
    "dev:clear": "npx expo start -c",
    "build:dev": "eas build --profile development-simulator --platform ios",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform ios",
    "build:ios:workflow": "eas workflow:run build-ios-production.yml",
    "build:submit:workflow": "eas workflow:run build-and-submit-ios.yml",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.11",
    "@expo/vector-icons": "^15.0.2",
    "@supabase/supabase-js": "^2.39.7",
    "babel-preset-expo": "~56.0.11",
    "expo": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.15",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "stream-browserify": "^3.0.0",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "volta": {
    "node": "24.16.0"
  }
}
