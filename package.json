{
  "name": "flower-sandbox",
  "main": "expo-router/entry",
  "version": "1.0.1",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "start": "npx expo start",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watchAll",
    "typecheck": "tsc --noEmit",
    "dev": "npx expo start",
    "dev:go": "npx expo start --go",
    "dev:tunnel": "npx expo start --tunnel",
    "dev:web": "npx expo start --web",
    "dev:clear": "npx expo start -c",
    "build:web": "node scripts/build-web.mjs",
    "preview:web": "pnpm build:web && node scripts/serve.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/landing.spec.ts",
    "test:e2e:integration": "E2E_RUN_STRIPE_FLOW=1 playwright test e2e/auth-subscription.spec.ts",
    "build:dev": "eas build --profile development-simulator --platform ios",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform ios",
    "build:ios:workflow": "eas workflow:run build-ios-production.yml",
    "submit:ios": "eas submit --platform ios --profile production",
    "app-store:doctor": "pnpm dlx git+https://github.com/TheScottyB/eas-app-store-kit.git#v0.1.1 doctor",
    "app-store:release": "pnpm dlx git+https://github.com/TheScottyB/eas-app-store-kit.git#v0.1.1 submit",
    "app-store:submit-review": "pnpm dlx git+https://github.com/TheScottyB/eas-app-store-kit.git#v0.1.1 submit --resume",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production",
    "screenshots:capture": "node scripts/capture_screenshots.mjs",
    "screenshots:verify": "node scripts/verify_screenshots.mjs",
    "qc-screenshots": "pnpm run screenshots:verify"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.worktrees/",
      "<rootDir>/supabase/",
      "<rootDir>/e2e/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/.worktrees/"
    ],
    "watchPathIgnorePatterns": [
      "<rootDir>/.worktrees/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(.pnpm|.deno|react-native|@react-native|@react-native-community|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))",
      "/node_modules/react-native-reanimated/plugin/",
      "/node_modules/@react-native/babel-preset/"
    ]
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.11",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "2.105.4",
    "babel-preset-expo": "~56.0.11",
    "expo": "~56.0.3",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.14",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-iap": "^4.3.1",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-router": "~56.2.5",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.15",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.1",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.8.3",
    "web-streams-polyfill": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.10",
    "@babel/runtime": "^7.29.2",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "expo-mcp": "^0.2.4",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
    "playwright": "^1.60.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true,
  "volta": {
    "node": "24.16.0"
  }
}
