{
  "cli": {
    "version": ">= 5.9.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "SUPABASE_PROJECT_ID": "your_dev_project_id",
        "EXPO_PUBLIC_SUPABASE_URL": "https://your_dev_project_id.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your_dev_anon_key",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_your_test_publishable_key",
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_DEBUG_MODE": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "SUPABASE_PROJECT_ID": "your_staging_project_id",
        "EXPO_PUBLIC_SUPABASE_URL": "https://your_staging_project_id.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your_staging_anon_key",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_your_test_publishable_key",
        "EXPO_PUBLIC_APP_ENV": "preview",
        "EXPO_PUBLIC_DEBUG_MODE": "false"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "SUPABASE_PROJECT_ID": "your_prod_project_id",
        "EXPO_PUBLIC_SUPABASE_URL": "https://your_prod_project_id.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your_prod_anon_key",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_live_your_live_publishable_key",
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_DEBUG_MODE": "false"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "environment": "development",
      "env": {
        "SUPABASE_PROJECT_ID": "your_dev_project_id",
        "EXPO_PUBLIC_SUPABASE_URL": "https://your_dev_project_id.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "your_dev_anon_key",
        "EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_test_your_test_publishable_key",
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_DEBUG_MODE": "true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "beilsco@gmail.com",
        "ascAppId": "6477183822",
        "appleTeamId": "3X872JR6P3",
        "sku": "PLAYSANDBOX2024"
      }
    }
  }
}
