{
  "expo": {
    "name": "FlowerSandbox",
    "slug": "flower-sandbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flowersandbox",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.flowersandbox",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "flowersandbox"
            ]
          }
        ],
        "UIRequiresFullScreen": true,
        "LSApplicationQueriesSchemes": [
          "https",
          "http"
        ]
      },
      "requireFullScreen": true,
      "associatedDomains": [],
      "appStoreUrl": "https://apps.apple.com/app/id6477183822"
    },
    "android": {
      "package": "com.djscottyb.flowersandbox",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "owner": "djscottyb",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "enabled": true
    },
    "extra": {
      "router": {}
    },
    "eas": {
      "projectId": "1eb49bf1-1ea0-490d-8ebc-992e30972908"
    }
  }
}
