{
  "expo": {
    "name": "FlowerSandbox",
    "slug": "flower-sandbox",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flowersandbox",
    "userInterfaceStyle": "automatic",
    "plugins": [
      "expo-router",
      "expo-iap",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.djscottyb.flowersandbox",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["flowersandbox"]
          }
        ],
        "UIRequiresFullScreen": true
      },
      "requireFullScreen": true,
      "associatedDomains": []
    },
    "android": {
      "package": "com.djscottyb.flowersandbox",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "owner": "djscottyb",
    "platforms": ["ios", "android", "web"],
    "assetBundlePatterns": ["**/*"],
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/1539cc0b-c507-4fac-8383-979f12f5bdd8"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1539cc0b-c507-4fac-8383-979f12f5bdd8"
      }
    },
    "experiments": {
      "baseUrl": "/app"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
